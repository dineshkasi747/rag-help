# Environment variables for the backend
ENVIRONMENT=development

# Database configuration for Standalone LOCAL run (SQLite zero-docker)
# For PostgreSQL use: postgresql+psycopg://researchmind:researchmind@localhost:5432/researchmind
DATABASE_URL=sqlite+aiosqlite:///./researchmind.db

# Qdrant configuration for Standalone LOCAL run
# Use local file path for zero-docker embedded storage or http://localhost:6333 if running Qdrant server
QDRANT_URL=./qdrant_storage

LLM_PROVIDER=groq
GROQ_API_KEY="your-groq-api-key-here"
LLM_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY="your-gemini-api-key-here"

# JWT Settings
RM_JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Upload directory
UPLOAD_DIR=./uploads

# RAG Configuration
EMBEDDING_PROVIDER=gemini
